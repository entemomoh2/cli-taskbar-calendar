#!/usr/bin/env bash
set -euo pipefail

month_class="${CLI_TASKBAR_CAL_MONTH_CLASS:-taskbar-month-calendar}"
year_class="${CLI_TASKBAR_CAL_YEAR_CLASS:-taskbar-year-calendar}"

close_by_class() {
  local class_name="$1"
  local ids

  ids="$(xdotool search --class "$class_name" 2>/dev/null || true)"
  [[ -n "$ids" ]] || return 1

  while IFS= read -r id; do
    [[ -n "$id" ]] || continue
    xdotool windowclose "$id" >/dev/null 2>&1 || true
  done <<<"$ids"

  return 0
}

# On X11, toggle behavior: close existing popup(s) on second click.
if command -v xdotool >/dev/null 2>&1; then
  if close_by_class "$month_class" || close_by_class "$year_class"; then
    exit 0
  fi
fi

exec taskbar-month-calendar "$@"
